---
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Translations } from '../i18n/en';
import type { Lang } from '../i18n/utils';

interface Props {
  t: Translations['nav'];
  lang: Lang;
}

const { t, lang } = Astro.props;

const tools = [
  {
    href: '/tools/ats-resume-checker',
    emoji: '🎯',
    title: t.atsChecker,
    sub: t.atsCheckerSub,
  },
];
---

<nav id="navbar" aria-label="Main navigation">
  <div style="max-width: 1180px; margin: 0 auto; padding: 0 1.5rem;">
    <div class="flex items-center justify-between" style="height: 64px;">

      <!-- Logo -->
      <a
        href={lang === 'en' ? '/' : `/${lang}/`}
        class="flex items-center gap-2"
        aria-label="Hirime — Home"
        style="text-decoration: none;"
      >
        <span style="
          font-size: 1.375rem;
          font-weight: 800;
          letter-spacing: -0.04em;
          color: var(--text-primary);
          font-family: 'Onest', system-ui, sans-serif;
        ">Hirime</span>
        <span style="
          width: 6px;
          height: 6px;
          border-radius: 50%;
          background-color: var(--accent);
          margin-bottom: 2px;
          display: inline-block;
        "></span>
      </a>

      <!-- Desktop nav links -->
      <div class="hidden md:flex items-center gap-1">
        <!-- Free tools dropdown -->
        <div class="nav-dropdown" id="nav-dropdown">
          <button
            type="button"
            class="btn-ghost dropdown-trigger"
            id="dropdown-trigger"
            aria-expanded="false"
            aria-haspopup="true"
            aria-controls="dropdown-menu"
          >
            {t.freeTools}
            <svg
              class="dropdown-chevron"
              width="10"
              height="10"
              viewBox="0 0 10 10"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M2 4l3 3 3-3"/>
            </svg>
          </button>
          <div class="dropdown-menu" id="dropdown-menu" role="menu">
            {tools.map((tool) => (
              <a href={tool.href} class="dropdown-item" role="menuitem">
                <span class="dropdown-emoji" aria-hidden="true">{tool.emoji}</span>
                <span class="dropdown-text">
                  <span class="dropdown-item-title">{tool.title}</span>
                  <span class="dropdown-item-sub">{tool.sub}</span>
                </span>
              </a>
            ))}
          </div>
        </div>

        <a href="#how-it-works" class="btn-ghost">{t.howItWorks}</a>
        <a href="#features" class="btn-ghost">{t.features}</a>
        <a href="#coming-soon" class="btn-ghost">{t.comingSoon}</a>
      </div>

      <!-- Right controls -->
      <div class="flex items-center gap-3">
        <div class="hidden sm:flex items-center gap-2">
          <LanguageSwitcher currentLang={lang} />
          <ThemeToggle />
        </div>
        <button id="open-waitlist-modal" class="btn-primary" style="font-size: 0.875rem; padding: 0.5rem 1.125rem;">
          {t.joinWaitlist}
        </button>
        <!-- Mobile menu button -->
        <button
          id="menu-toggle"
          class="md:hidden"
          aria-label="Open menu"
          style="
            width: 2.25rem;
            height: 2.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 0.5rem;
            border: 1.5px solid var(--border);
            background: var(--bg-card);
            cursor: pointer;
            color: var(--text-secondary);
            transition: color 0.2s ease, background-color 0.2s ease;
          "
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden pb-4"
      style="border-top: 1px solid var(--border); padding-top: 1rem; margin-top: 0;"
    >
      <div class="flex flex-col gap-1">
        <div class="mobile-section-label">{t.freeTools}</div>
        {tools.map((tool) => (
          <a href={tool.href} class="btn-ghost mobile-tool-link" style="justify-content: flex-start;">
            <span aria-hidden="true" style="margin-right: 0.5rem;">{tool.emoji}</span>
            <span>{tool.title}</span>
          </a>
        ))}
        <div style="height: 0.5rem;"></div>
        <a href="#how-it-works" class="btn-ghost" style="justify-content: flex-start;">{t.howItWorks}</a>
        <a href="#features" class="btn-ghost" style="justify-content: flex-start;">{t.features}</a>
        <a href="#coming-soon" class="btn-ghost" style="justify-content: flex-start;">{t.comingSoon}</a>
      </div>
      <div class="flex items-center gap-3 mt-4">
        <LanguageSwitcher currentLang={lang} />
        <ThemeToggle />
      </div>
    </div>
  </div>
</nav>

<style>
  .nav-dropdown {
    position: relative;
  }
  .dropdown-trigger {
    gap: 0.375rem;
  }
  .dropdown-chevron {
    transition: transform 0.2s ease;
    opacity: 0.7;
  }
  .nav-dropdown.open .dropdown-chevron {
    transform: rotate(180deg);
  }
  .nav-dropdown.open .dropdown-trigger {
    color: var(--text-primary);
    background-color: var(--bg-secondary);
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    min-width: 280px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: var(--shadow-lg);
    padding: 6px;
    opacity: 0;
    transform: translateY(-4px);
    pointer-events: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
    z-index: 110;
  }
  .nav-dropdown.open .dropdown-menu {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .dropdown-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    border-radius: 10px;
    text-decoration: none;
    color: var(--text-primary);
    transition: background-color 0.15s ease;
  }
  .dropdown-item:hover {
    background-color: var(--bg-secondary);
  }
  .dropdown-emoji {
    width: 32px;
    height: 32px;
    border-radius: 9px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    display: grid;
    place-items: center;
    font-size: 16px;
    flex: none;
  }
  .dropdown-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .dropdown-item-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.25;
  }
  .dropdown-item-sub {
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.3;
  }

  .mobile-section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0.5rem 0.75rem 0.25rem;
  }
  .mobile-tool-link {
    padding-left: 1.25rem;
  }
</style>

<script>
  // ─── Nav dropdown (Free tools) ───────────────────────────────────────
  const dropdown = document.getElementById('nav-dropdown');
  const trigger = document.getElementById('dropdown-trigger');
  const menu = document.getElementById('dropdown-menu');

  if (dropdown && trigger && menu) {
    let hoverTimeout: number | undefined;

    const open = () => {
      window.clearTimeout(hoverTimeout);
      dropdown.classList.add('open');
      trigger.setAttribute('aria-expanded', 'true');
    };
    const close = () => {
      dropdown.classList.remove('open');
      trigger.setAttribute('aria-expanded', 'false');
    };
    const scheduleClose = () => {
      window.clearTimeout(hoverTimeout);
      hoverTimeout = window.setTimeout(close, 140);
    };

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown.classList.contains('open') ? close() : open();
    });
    dropdown.addEventListener('mouseenter', open);
    dropdown.addEventListener('mouseleave', scheduleClose);

    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target as Node)) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }
</script>
