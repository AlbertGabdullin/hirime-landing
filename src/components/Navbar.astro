---
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Translations } from '../i18n/en';
import type { Lang } from '../i18n/utils';

interface Props {
  t: Translations['nav'];
  lang: Lang;
}

const { t, lang } = Astro.props;
---

<nav id="navbar" aria-label="Main navigation">
  <div style="max-width: 1180px; margin: 0 auto; padding: 0 1.5rem;">
    <div class="flex items-center justify-between" style="height: 64px;">

      <!-- Logo -->
      <a
        href={lang === 'en' ? '/' : `/${lang}/`}
        class="flex items-center gap-2"
        aria-label="Hirime — Home"
        style="text-decoration: none;"
      >
        <span style="
          font-size: 1.375rem;
          font-weight: 800;
          letter-spacing: -0.04em;
          color: var(--text-primary);
          font-family: 'Onest', system-ui, sans-serif;
        ">Hirime</span>
        <span style="
          width: 6px;
          height: 6px;
          border-radius: 50%;
          background-color: var(--accent);
          margin-bottom: 2px;
          display: inline-block;
        "></span>
      </a>

      <!-- Desktop nav links -->
      <div class="hidden md:flex items-center gap-1">
        <a href="#how-it-works" class="btn-ghost">{t.howItWorks}</a>
        <a href="#features" class="btn-ghost">{t.features}</a>
        <a href="#coming-soon" class="btn-ghost">{t.comingSoon}</a>
      </div>

      <!-- Right controls -->
      <div class="flex items-center gap-3">
        <div class="hidden sm:flex items-center gap-2">
          <LanguageSwitcher currentLang={lang} />
          <ThemeToggle />
        </div>
        <button id="open-waitlist-modal" class="btn-primary" style="font-size: 0.875rem; padding: 0.5rem 1.125rem;">
          {t.joinWaitlist}
        </button>
        <!-- Mobile menu button -->
        <button
          id="menu-toggle"
          class="md:hidden"
          aria-label="Open menu"
          style="
            width: 2.25rem;
            height: 2.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 0.5rem;
            border: 1.5px solid var(--border);
            background: var(--bg-card);
            cursor: pointer;
            color: var(--text-secondary);
            transition: color 0.2s ease, background-color 0.2s ease;
          "
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden pb-4"
      style="border-top: 1px solid var(--border); padding-top: 1rem; margin-top: 0;"
    >
      <div class="flex flex-col gap-1">
        <a href="#how-it-works" class="btn-ghost" style="justify-content: flex-start;">{t.howItWorks}</a>
        <a href="#features" class="btn-ghost" style="justify-content: flex-start;">{t.features}</a>
        <a href="#coming-soon" class="btn-ghost" style="justify-content: flex-start;">{t.comingSoon}</a>
      </div>
      <div class="flex items-center gap-3 mt-4">
        <LanguageSwitcher currentLang={lang} />
        <ThemeToggle />
      </div>
    </div>
  </div>
</nav>
