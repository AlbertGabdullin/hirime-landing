</style>

<script>
  // ─── ATS Resume Checker — state machine ───────────────────────────────
  type Finding = { kind: 'ok' | 'warn' | 'bad'; text: string };
  type Category = {
    key: string;
    emoji: string;
    name: string;
    score: number;
    findings: Finding[];
    tip: string;
  };
  type Report = { overall: number; categories: Category[]; filename?: string; pages?: number; words?: number };

  const MAX_BYTES = 5 * 1024 * 1024;

  const els = {
    intro: document.getElementById('tool-intro') as HTMLElement,
    trustRow: document.getElementById('trust-row') as HTMLElement,
    idle: document.getElementById('state-idle') as HTMLElement,
    selected: document.getElementById('state-selected') as HTMLElement,
    analyzing: document.getElementById('state-analyzing') as HTMLElement,
    error: document.getElementById('state-error') as HTMLElement,
    results: document.getElementById('state-results') as HTMLElement,
    dropzone: document.getElementById('dropzone') as HTMLElement,
    fileInput: document.getElementById('file-input') as HTMLInputElement,
    browseBtn: document.getElementById('browse-btn') as HTMLButtonElement,
    fileName: document.getElementById('file-name') as HTMLElement,
    fileSub: document.getElementById('file-sub') as HTMLElement,
    fileRemove: document.getElementById('file-remove') as HTMLButtonElement,
    analyzeBtn: document.getElementById('analyze-btn') as HTMLButtonElement,
    anaMsg: document.getElementById('ana-msg') as HTMLElement,
    anaBarFill: document.getElementById('ana-bar-fill') as HTMLElement,
    anaSteps: document.getElementById('ana-steps') as HTMLElement,
    errorMsg: document.getElementById('error-msg') as HTMLElement,
    errorRetry: document.getElementById('error-retry') as HTMLButtonElement,
    verdictPill: document.getElementById('verdict-pill') as HTMLElement,
    verdictLabel: document.getElementById('verdict-label') as HTMLElement,
    verdictSub: document.getElementById('verdict-sub') as HTMLElement,
    gaugeFill: document.getElementById('gauge-fill') as unknown as SVGCircleElement,
    gaugeNum: document.getElementById('gauge-num') as HTMLElement,
    catGrid: document.getElementById('cat-grid') as HTMLElement,
    scanAnother: document.getElementById('scan-another') as HTMLButtonElement,
    openWaitlistFromResults: document.getElementById('open-waitlist-modal-results') as HTMLButtonElement,
  };

  const ANA_MESSAGES = [
    'Extracting text from your PDF…',
    'Checking ATS parseability…',
    'Analyzing keywords and structure…',
    'Generating your report…',
  ];

  function setVisible(node: HTMLElement, visible: boolean) {
    node.classList.toggle('hidden', !visible);
  }

  function showState(s: 'idle' | 'selected' | 'analyzing' | 'error' | 'results') {
    setVisible(els.idle, s === 'idle');
    setVisible(els.selected, s === 'selected');
    setVisible(els.analyzing, s === 'analyzing');
    setVisible(els.error, s === 'error');
    setVisible(els.results, s === 'results');
    setVisible(els.intro, s !== 'results');
    setVisible(els.trustRow, s !== 'results');
  }

  function renderAnalyzingSteps(activeIdx: number) {
    els.anaSteps.innerHTML = ANA_MESSAGES.map((m, i) => {
      const cls = i < activeIdx ? 'done' : i === activeIdx ? 'active' : '';
      const dot =
        i < activeIdx
          ? '<svg width="8" height="8" viewBox="0 0 8 8"><path d="M1 4l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>'
          : '';
      return `<div class="ana-step ${cls}"><span class="dot">${dot}</span><span>${m}</span></div>`;
    }).join('');
  }

  function verdictFor(score: number) {
    if (score >= 75) return { pill: 'good', label: 'Excellent', sub: 'Your resume is well-optimized for most ATS systems. A few small tweaks will push it higher.' };
    if (score >= 50) return { pill: 'warn', label: 'Good — with some fixes', sub: 'Most ATS systems will parse your resume correctly, but there are clear opportunities to improve.' };
    return { pill: 'bad', label: 'Needs work', sub: 'Several issues are likely preventing your resume from being parsed correctly. Fix these first.' };
  }

  function colorForScore(score: number) {
    if (score >= 75) return 'var(--ats-good)';
    if (score >= 50) return 'var(--ats-warn)';
    return 'var(--ats-bad)';
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
  }

  function renderReport(report: Report) {
    const v = verdictFor(report.overall);
    els.verdictPill.className = `verdict-pill ${v.pill}`;
    els.verdictPill.textContent = `● ${v.label}`;
    els.verdictLabel.textContent = `Your resume scored ${report.overall} / 100`;
    els.verdictSub.textContent = v.sub;
    els.gaugeNum.textContent = String(report.overall);

    const r = 100;
    const C = 2 * Math.PI * r;
    const offset = C * (1 - report.overall / 100);
    els.gaugeFill.setAttribute('stroke-dasharray', String(C));
    els.gaugeFill.setAttribute('stroke', colorForScore(report.overall));
    // force reflow then animate
    els.gaugeFill.setAttribute('stroke-dashoffset', String(C));
    requestAnimationFrame(() => {
      els.gaugeFill.setAttribute('stroke-dashoffset', String(offset));
    });

    els.catGrid.innerHTML = report.categories
      .map((c) => {
        const color = colorForScore(c.score);
        const findings = c.findings
          .map(
            (f) =>
              `<div class="finding ${f.kind}">
                 <span class="finding-mark">${f.kind === 'ok' ? '✓' : f.kind === 'warn' ? '!' : '×'}</span>
                 <span>${escapeHtml(f.text)}</span>
               </div>`,
          )
          .join('');
        return `
          <div class="cat-card">
            <div class="cat-head">
              <div class="cat-title">
                <div class="cat-emoji">${escapeHtml(c.emoji)}</div>
                <div class="cat-name">${escapeHtml(c.name)}</div>
              </div>
              <div class="cat-score"><b>${c.score}</b> / 100</div>
            </div>
            <div class="cat-bar"><div class="cat-bar-fill" style="width: ${c.score}%; background: ${color};"></div></div>
            <div class="findings">${findings}</div>
            <div class="fix-tip"><b>How to fix:</b> ${escapeHtml(c.tip)}</div>
          </div>`;
      })
      .join('');
  }

  let currentFile: File | null = null;
  let analyzing = false;

  function chooseFile(file: File) {
    if (file.size > MAX_BYTES) {
      showError('File exceeds 5MB limit. Please upload a smaller PDF.');
      return;
    }
    const isPdf =
      file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf');
    if (!isPdf) {
      showError('PDF files only. Please export your resume as a PDF first.');
      return;
    }
    currentFile = file;
    els.fileName.textContent = file.name;
    els.fileSub.textContent = `${(file.size / 1024).toFixed(1)} KB · ready to scan`;
    showState('selected');
  }

  function showError(msg: string) {
    els.errorMsg.textContent = msg;
    showState('error');
  }

  function reset() {
    currentFile = null;
    els.fileInput.value = '';
    showState('idle');
  }

  async function startAnalysis() {
    if (!currentFile || analyzing) return;
    analyzing = true;
    showState('analyzing');
    renderAnalyzingSteps(0);
    els.anaMsg.textContent = ANA_MESSAGES[0];
    els.anaBarFill.style.width = '25%';

    // Visual pacing — advance UI through messages while the request is in flight
    const visualTimers: number[] = [];
    const advance = (i: number, pct: number) => {
      els.anaMsg.textContent = ANA_MESSAGES[i];
      els.anaBarFill.style.width = `${pct}%`;
      renderAnalyzingSteps(i);
    };
    visualTimers.push(window.setTimeout(() => advance(1, 50), 700));
    visualTimers.push(window.setTimeout(() => advance(2, 75), 1600));

    const form = new FormData();
    form.append('file', currentFile);

    try {
      const res = await fetch('/api/ats-check', { method: 'POST', body: form });
      const data = await res.json();
      visualTimers.forEach(clearTimeout);
      if (!res.ok) {
        showError(data?.error || 'Analysis failed — please try again.');
        analyzing = false;
        return;
      }
      advance(3, 100);
      // brief pause so users see the final step before transition
      window.setTimeout(() => {
        renderReport(data as Report);
        showState('results');
        analyzing = false;
        document.getElementById('state-results')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 350);
    } catch (err) {
      visualTimers.forEach(clearTimeout);
      console.error(err);
      showError('Network error — please check your connection and try again.');
      analyzing = false;
    }
  }

  // ─── Events ───────────────────────────────────────────────────────────
  els.browseBtn.addEventListener('click', () => els.fileInput.click());
  els.fileInput.addEventListener('change', (e) => {
    const f = (e.target as HTMLInputElement).files?.[0];
    if (f) chooseFile(f);
  });

  ['dragenter', 'dragover'].forEach((evt) =>
    els.dropzone.addEventListener(evt, (e) => {
      e.preventDefault();
      els.dropzone.classList.add('hot');
    }),
  );
  ['dragleave', 'drop'].forEach((evt) =>
    els.dropzone.addEventListener(evt, (e) => {
      e.preventDefault();
      els.dropzone.classList.remove('hot');
    }),
  );
  els.dropzone.addEventListener('drop', (e) => {
    const f = (e as DragEvent).dataTransfer?.files?.[0];
    if (f) chooseFile(f);
  });

  els.fileRemove.addEventListener('click', reset);
  els.analyzeBtn.addEventListener('click', startAnalysis);
  els.errorRetry.addEventListener('click', reset);
  els.scanAnother.addEventListener('click', reset);

  // Results-screen CTA opens the same waitlist modal as the navbar
  els.openWaitlistFromResults?.addEventListener('click', () => {
    document.getElementById('open-waitlist-modal')?.dispatchEvent(new MouseEvent('click'));
  });

  // ─── FAQ accordion ────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.ats-tool .faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      if (!item) return;
      const open = item.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  });
</script>
