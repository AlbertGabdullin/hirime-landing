---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { en as base } from '../../i18n/en';

const lang = 'en' as const;

const t = {
  ...base,
  meta: {
    title: 'Free ATS Resume Checker — Scan Your Resume in 30 Seconds | Hirime',
    description:
      'Free ATS resume checker. Upload your PDF and get an instant report on whether applicant tracking systems can read your resume. 100% free, no signup.',
    keywords:
      'ATS resume checker, ATS scanner, ATS resume scan, is my resume ATS friendly, free ATS resume check, resume ATS test, applicant tracking system checker',
    ogTitle: 'Free ATS Resume Checker — Hirime',
    ogDescription:
      'Upload your resume and get an instant ATS readability score, category breakdown, and fixes. 100% free.',
  },
} as const;

const faqs = [
  {
    q: 'What is an ATS resume checker?',
    a: 'An ATS resume checker scans your resume the way an Applicant Tracking System would — testing whether the software can correctly extract your name, work history, skills and education from the file. It then flags formatting issues, missing sections, and weak content so you can fix them before you apply.',
  },
  {
    q: 'Is this ATS checker really free?',
    a: 'Yes. There is no signup, no email, no credit card, and no paywall. We built this as a free tool to introduce people to Hirime — our AI resume builder that goes a step further and rewrites your resume to match each job.',
  },
  {
    q: 'How accurate is the ATS score?',
    a: 'Our analyzer is modeled on the parsing rules used by major Applicant Tracking Systems (Workday, Greenhouse, Lever, Taleo, iCIMS). It tests the same signals: layout, fonts, section headers, encoding, and content density. No checker can perfectly mirror every ATS in production, but the issues we flag are the ones that consistently cause real-world parsing failures.',
  },
  {
    q: 'Which ATS platforms does this support?',
    a: 'We test against the parsing logic of Workday, Greenhouse, Lever, Taleo, iCIMS, SmartRecruiters, BambooHR and Ashby — the systems used by the vast majority of Fortune 500 employers and high-growth startups.',
  },
  {
    q: "What's the best resume format for ATS?",
    a: 'A single-column PDF with standard section headers ("Work Experience", "Education", "Skills"), a clean sans-serif font (Helvetica, Calibri, Arial), no tables, no images, no text boxes, and contact information in the main body — not the header or footer. Save from the source document directly to PDF; never scan or screenshot.',
  },
  {
    q: 'Should I use a template from Word or Canva?',
    a: 'Word templates are generally safe. Canva and other design-first templates often produce PDFs with multi-column layouts, decorative typography, or text-as-image elements that ATS parsers struggle with. If you use a designer template, run it through this checker before submitting.',
  },
  {
    q: 'Do ATS systems read PDFs?',
    a: 'Yes — modern ATS platforms read PDFs reliably, provided the PDF contains real text (not a scanned image). Older systems can struggle with complex layouts, so the safest path is a text-based PDF exported from your word processor.',
  },
  {
    q: 'How can I make my resume ATS-friendly?',
    a: "Use a single-column layout, standard section headings, a common font, plain bullet points, and quantified achievements. Avoid graphics, columns, tables, headers and footers. Run your resume through this checker and address each flagged item — that's the fastest path to an ATS-ready file.",
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Hirime ATS Resume Checker',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  url: 'https://hirime.com/tools/ats-resume-checker',
};
---

<BaseLayout t={t} lang={lang}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} />
  </Fragment>

  <Navbar t={t.nav} lang={lang} />

  <main class="ats-tool" style="padding-top: 64px;">
    <!-- HERO + UPLOAD / RESULTS -->
    <section class="ats-hero">
      <div class="container" id="tool-root">
        <div id="tool-intro" style="text-align: center; margin-bottom: 40px;">
          <span class="eyebrow"><span class="spark">✦</span> Free ATS Resume Checker</span>
          <h1 class="hero-headline">
            Is your resume <span class="serif-em">ATS-friendly?</span><br />
            Find out in 30 seconds.
          </h1>
          <p class="lede hero-lede">
            Upload your resume and get an instant report on whether applicant tracking systems can actually read it — and exactly how to fix what they can't.
          </p>
        </div>

        <!-- IDLE -->
        <div id="state-idle" class="upload-card">
          <div class="dropzone" id="dropzone">
            <div class="drop-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            </div>
            <div class="drop-title">Drop your resume here</div>
            <div class="drop-sub">or browse from your device</div>
            <div class="drop-actions">
              <button type="button" class="ats-btn ats-btn-primary ats-btn-lg" id="browse-btn">Choose PDF</button>
            </div>
            <input id="file-input" class="sr-only" type="file" accept=".pdf,application/pdf" aria-label="Upload resume PDF" />
            <div class="file-meta">PDF only · max 5MB · processed securely, never stored</div>
          </div>
        </div>

        <!-- SELECTED -->
        <div id="state-selected" class="upload-card hidden">
          <div style="padding: 16px;">
            <div class="file-row">
              <div class="file-thumb" aria-hidden="true">PDF</div>
              <div class="file-info">
                <div class="file-name" id="file-name"></div>
                <div class="file-sub" id="file-sub"></div>
              </div>
              <button type="button" class="file-remove" id="file-remove" aria-label="Remove file">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </button>
            </div>
            <button type="button" class="ats-btn ats-btn-primary ats-btn-lg" id="analyze-btn" style="width: 100%; justify-content: center;">
              Scan resume →
            </button>
          </div>
        </div>

        <!-- ANALYZING -->
        <div id="state-analyzing" class="upload-card hidden">
          <div class="analyzing">
            <div class="ana-spinner" aria-hidden="true"></div>
            <div class="ana-msg" id="ana-msg">Extracting text from your PDF…</div>
            <div class="ana-bar"><div class="ana-bar-fill" id="ana-bar-fill" style="width: 25%;"></div></div>
            <div class="ana-steps" id="ana-steps"></div>
          </div>
        </div>

        <!-- ERROR -->
        <div id="state-error" class="upload-card hidden">
          <div style="padding: 32px; text-align: center;">
            <div class="drop-icon" style="background: var(--ats-bad-soft); color: var(--ats-bad);" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <div class="drop-title">Couldn't scan that file</div>
            <div class="drop-sub" id="error-msg">Something went wrong. Please try again.</div>
            <div class="drop-actions">
              <button type="button" class="ats-btn ats-btn-primary ats-btn-lg" id="error-retry">Try again</button>
            </div>
          </div>
        </div>

        <!-- RESULTS -->
        <div id="state-results" class="results hidden">
          <div class="results-hero">
            <div class="verdict-pill" id="verdict-pill">●</div>
            <div class="gauge-wrap" id="gauge-wrap">
              <svg viewBox="0 0 240 240" aria-hidden="true">
                <circle class="gauge-track" cx="120" cy="120" r="100" fill="none" stroke-width="14"/>
                <circle class="gauge-fill" id="gauge-fill" cx="120" cy="120" r="100" fill="none" stroke-width="14" stroke-linecap="round" stroke-dasharray="628.32" stroke-dashoffset="628.32"/>
              </svg>
              <div class="gauge-num">
                <div class="gauge-num-inner">
                  <div class="num" id="gauge-num">0</div>
                  <div class="out">/ 100</div>
                </div>
              </div>
            </div>
            <div class="verdict" id="verdict-label">Your resume scored 0 / 100</div>
            <div class="verdict-sub" id="verdict-sub"></div>
          </div>

          <div class="cat-grid" id="cat-grid"></div>

          <div class="results-cta">
            <h3>Fix every issue automatically with Hirime.</h3>
            <p>Hirime's AI rewrites your resume to pass ATS systems and match any job description.</p>
            <div class="actions">
              <button type="button" class="ats-btn ats-btn-primary ats-btn-lg" id="open-waitlist-modal-results">Join the Waitlist →</button>
            </div>
          </div>

          <div class="scan-another">
            <button type="button" id="scan-another">← Scan another resume</button>
          </div>
        </div>

        <div class="trust-row" id="trust-row">
          <span><span class="check">✓</span> 100% free</span>
          <span><span class="check">✓</span> No signup needed</span>
          <span><span class="check">✓</span> Your resume isn't stored</span>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="how-it-works">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow"><span class="spark">✦</span> How it works</span>
          <h2>From upload to <span class="serif-em">actionable report</span> in&nbsp;under a&nbsp;minute.</h2>
        </div>
        <div class="steps">
          <div class="step">
            <div class="step-num"><span class="num-dot"></span>01 — UPLOAD</div>
            <div class="step-emoji">📤</div>
            <h3>Drop in your PDF</h3>
            <p>No signup, no email. Pick a file and we get to work.</p>
          </div>
          <div class="step">
            <div class="step-num"><span class="num-dot"></span>02 — ANALYZE</div>
            <div class="step-emoji">🤖</div>
            <h3>AI scans 50+ ATS factors</h3>
            <p>Formatting, parseability, action verbs, section structure, keyword density, and red flags.</p>
          </div>
          <div class="step">
            <div class="step-num"><span class="num-dot"></span>03 — FIX</div>
            <div class="step-emoji">📊</div>
            <h3>Get specific fixes</h3>
            <p>Category-by-category breakdown with exact issues and how to resolve each one.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="features" style="padding-top: 48px;">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow"><span class="spark">✦</span> What we check</span>
          <h2>Every signal an ATS uses to parse your&nbsp;resume.</h2>
          <p class="lede">We test against the same parsing logic used by major Applicant Tracking Systems.</p>
        </div>
        <div class="features">
          <div class="feature">
            <div class="feat-emoji">🔍</div>
            <h3>Cross-ATS parseability</h3>
            <p>Tested against Workday, Greenhouse, Lever, Taleo, and iCIMS parsing engines.</p>
          </div>
          <div class="feature">
            <div class="feat-emoji">🎯</div>
            <h3>Keyword match scoring</h3>
            <p>Action verbs, density, and presence of role-relevant hard skills are scored automatically.</p>
          </div>
          <div class="feature">
            <div class="feat-emoji">📐</div>
            <h3>Layout &amp; formatting</h3>
            <p>Detects multi-column layouts, tables, headers/footers, and graphic elements that break parsing.</p>
          </div>
          <div class="feature">
            <div class="feat-emoji">✍️</div>
            <h3>Action verb strength</h3>
            <p>Flags weak openers and missing quantification. Suggests stronger replacements.</p>
          </div>
          <div class="feature">
            <div class="feat-emoji">🔤</div>
            <h3>Fonts &amp; encoding</h3>
            <p>Catches special characters, unusual fonts, and ligatures that ATS systems misread.</p>
          </div>
          <div class="feature">
            <div class="feat-emoji">📑</div>
            <h3>Section completeness</h3>
            <p>Verifies you have all standard sections under names ATS systems are trained to find.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY ATS -->
    <section>
      <div class="container">
        <div class="section-head" style="margin-bottom: 56px;">
          <span class="eyebrow"><span class="spark">✦</span> Why it matters</span>
          <h2>Why ATS optimization <span class="serif-em">matters</span> in&nbsp;2026.</h2>
        </div>
        <div class="why-grid">
          <div class="why-text">
            <p>Before a recruiter ever reads your resume, an <b>Applicant Tracking System</b> reads it first. ATS software parses your PDF, extracts structured data, and ranks you against the job description — all in milliseconds.</p>
            <p>If your formatting trips up the parser (tables, columns, embedded images, decorative fonts), entire sections of your experience may be invisible to the recruiter. Even strong candidates get filtered out before a human ever sees the file.</p>
            <p>Optimizing for ATS isn't about gaming the system — it's about making sure the system can actually read what you've already built.</p>
          </div>
          <div class="why-stat">
            <div class="stat-num">75%</div>
            <div class="stat-label">of resumes are rejected by ATS before a human ever sees them.</div>
          </div>
        </div>
        <div class="ats-row">
          <div class="ats-row-label">Compatible with the systems used by 90% of Fortune 500</div>
          <span class="ats-chip">Workday</span>
          <span class="ats-chip">Greenhouse</span>
          <span class="ats-chip">Lever</span>
          <span class="ats-chip">Taleo</span>
          <span class="ats-chip">iCIMS</span>
          <span class="ats-chip">SmartRecruiters</span>
          <span class="ats-chip">BambooHR</span>
          <span class="ats-chip">Ashby</span>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow"><span class="spark">✦</span> FAQ</span>
          <h2>Frequently asked questions</h2>
        </div>
        <div class="faq">
          {faqs.map((f, i) => (
            <div class={`faq-item ${i === 0 ? 'open' : ''}`}>
              <button class="faq-q" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span>{f.q}</span>
                <span class="faq-icon" aria-hidden="true">
                  <svg width="10" height="10" viewBox="0 0 10 10"><path d="M5 1v8M1 5h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </span>
              </button>
              <div class="faq-a"><div class="faq-a-inner">{f.a}</div></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section id="coming-soon">
      <div class="container">
        <div class="final-cta">
          <span class="eyebrow"><span class="spark">✦</span> Beyond the checker</span>
          <h2>Stop checking. <span class="serif-em">Start getting hired.</span></h2>
          <p>Hirime auto-tailors your resume for every job application. Join the waitlist for early access.</p>
          <form class="email-form waitlist-form" id="tool-waitlist-form" novalidate>
            <input type="email" name="email" required placeholder="you@example.com" aria-label="Email address" />
            <button class="ats-btn ats-btn-primary" type="submit">Join Waitlist</button>
            <div class="success-msg-tool" style="display: none;">✓ You're on the list. We'll be in touch soon. 🎉</div>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer t={t.footer} lang={lang} />
</BaseLayout>

<style is:global>
  .ats-tool {
    /* Scoped design tokens (purple/cream from the design spec) */
    --ats-bg: var(--bg-primary);
    --ats-bg-elev: var(--bg-card);
    --ats-ink: var(--text-primary);
    --ats-ink-2: var(--text-secondary);
    --ats-ink-3: var(--text-muted);
    --ats-line: var(--border);
    --ats-line-2: color-mix(in oklab, var(--border) 70%, var(--text-muted));
    --ats-accent: var(--accent);
    --ats-accent-ink: var(--accent-fg);
    --ats-accent-soft: color-mix(in oklab, var(--accent) 16%, var(--bg-card));
    --ats-good: #1a8a4a;
    --ats-warn: #c87b14;
    --ats-bad: #c43a3a;
    --ats-good-soft: #e5f4ea;
    --ats-warn-soft: #faecd5;
    --ats-bad-soft: #fae5e5;
    --ats-radius: 18px;
    --ats-radius-lg: 24px;
    --ats-shadow-sm: 0 1px 0 rgba(17,17,15,.04), 0 1px 2px rgba(17,17,15,.04);
    --ats-shadow-md: 0 1px 0 rgba(17,17,15,.04), 0 8px 24px -8px rgba(17,17,15,.10);
    font-family: 'Onest', system-ui, sans-serif;
    color: var(--ats-ink);
    line-height: 1.55;
  }
  .dark .ats-tool {
    --ats-accent-soft: color-mix(in oklab, var(--accent) 22%, var(--bg-card));
    --ats-good-soft: #11261a;
    --ats-warn-soft: #2b1f0c;
    --ats-bad-soft: #2b1313;
    --ats-shadow-sm: 0 1px 0 rgba(0,0,0,.4), 0 1px 2px rgba(0,0,0,.3);
    --ats-shadow-md: 0 1px 0 rgba(0,0,0,.4), 0 12px 32px -12px rgba(0,0,0,.5);
  }

  .ats-tool .hidden { display: none !important; }
  .ats-tool .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

  .ats-tool h1, .ats-tool h2, .ats-tool h3 { letter-spacing: -0.025em; line-height: 1.1; margin: 0; font-weight: 700; }
  .ats-tool h1 { font-size: clamp(40px, 6vw, 64px); letter-spacing: -0.035em; }
  .ats-tool h2 { font-size: clamp(32px, 4.2vw, 44px); }
  .ats-tool h3 { font-size: 19px; letter-spacing: -0.015em; line-height: 1.3; }
  .ats-tool .serif-em {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic; font-weight: 400; letter-spacing: -0.02em;
  }
  .ats-tool .lede {
    font-size: 18px; color: var(--ats-ink-2); max-width: 580px;
    margin: 0 auto; line-height: 1.5;
  }

  .ats-tool section { padding: 96px 0; }
  @media (max-width: 720px) { .ats-tool section { padding: 64px 0; } }
  .ats-tool .ats-hero { padding-top: 72px; padding-bottom: 80px; text-align: center; }
  .ats-tool .section-head { text-align: center; margin-bottom: 56px; }
  .ats-tool .section-head .eyebrow { margin-bottom: 20px; }
  .ats-tool .section-head .lede { margin-top: 18px; }

  .ats-tool .eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 500; color: var(--ats-ink-2);
    padding: 6px 12px; border: 1px solid var(--ats-line); border-radius: 999px;
    background: var(--ats-bg-elev);
  }
  .ats-tool .eyebrow .spark { color: var(--ats-accent); font-size: 14px; }

  .ats-tool .hero-headline { margin: 22px auto 18px; max-width: 880px; }
  .ats-tool .hero-lede { margin: 0 auto 40px; }

  .ats-tool .ats-btn {
    font-size: 14px; font-weight: 600;
    padding: 10px 16px; border-radius: 10px;
    transition: transform .08s ease, background .15s, color .15s, border-color .15s, filter .15s;
    display: inline-flex; align-items: center; gap: 6px;
    border: none; cursor: pointer; font-family: inherit;
  }
  .ats-tool .ats-btn:active { transform: translateY(1px); }
  .ats-tool .ats-btn-primary { background: var(--ats-accent); color: var(--ats-accent-ink); }
  .ats-tool .ats-btn-primary:hover { filter: brightness(1.05); }
  .ats-tool .ats-btn-lg { padding: 14px 22px; font-size: 15px; border-radius: 12px; }

  /* TRUST ROW */
  .ats-tool .trust-row {
    display: flex; gap: 28px; justify-content: center; flex-wrap: wrap;
    margin-top: 32px; font-size: 13px; color: var(--ats-ink-2);
  }
  .ats-tool .trust-row span { display: inline-flex; align-items: center; gap: 6px; }
  .ats-tool .trust-row .check {
    width: 16px; height: 16px; border-radius: 999px;
    background: var(--ats-good-soft); color: var(--ats-good);
    display: inline-grid; place-items: center;
    font-size: 10px; font-weight: 700;
  }
  .dark .ats-tool .trust-row .check { color: #6fd99a; }

  /* UPLOAD */
  .ats-tool .upload-card {
    max-width: 720px; margin: 0 auto;
    background: var(--ats-bg-elev);
    border: 1px solid var(--ats-line);
    border-radius: var(--ats-radius-lg);
    padding: 8px;
    box-shadow: var(--ats-shadow-md);
  }
  .ats-tool .dropzone {
    border: 2px dashed var(--ats-line-2);
    border-radius: 18px;
    padding: 56px 32px;
    text-align: center;
    transition: background .2s, border-color .2s;
    background: color-mix(in oklab, var(--ats-bg) 50%, transparent);
    position: relative;
  }
  .ats-tool .dropzone.hot {
    border-color: var(--ats-accent);
    background: var(--ats-accent-soft);
  }
  .ats-tool .drop-icon {
    width: 56px; height: 56px; border-radius: 16px;
    background: var(--ats-accent-soft); color: var(--ats-accent);
    margin: 0 auto 16px;
    display: grid; place-items: center;
  }
  .ats-tool .drop-title { font-size: 18px; font-weight: 600; margin-bottom: 6px; letter-spacing: -0.015em; }
  .ats-tool .drop-sub { font-size: 14px; color: var(--ats-ink-3); margin-bottom: 22px; }
  .ats-tool .drop-actions { display: flex; gap: 10px; justify-content: center; align-items: center; flex-wrap: wrap; }
  .ats-tool .file-meta {
    font-size: 12px; color: var(--ats-ink-3); margin-top: 18px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, monospace;
  }

  .ats-tool .file-row {
    display: flex; align-items: center; gap: 14px;
    padding: 18px;
    background: var(--ats-bg);
    border-radius: 14px;
    border: 1px solid var(--ats-line);
    margin-bottom: 12px;
  }
  .ats-tool .file-thumb {
    width: 44px; height: 56px;
    background: var(--ats-accent-soft); color: var(--ats-accent);
    border-radius: 6px;
    display: grid; place-items: center;
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; font-weight: 600;
    flex: none;
  }
